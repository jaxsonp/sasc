{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "CMake: Configure",
			"type": "shell",
			"command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug",
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "CMake: Build",
			"type": "shell",
			"command": "cmake --build build",
			"dependsOn": [
				"CMake: Configure"
			],
			"problemMatcher": [
				"$gcc",
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}